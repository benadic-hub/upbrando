# =========================
# Upbrando EMS Backend Env
# =========================
# Copy to .env for local development.
# Do not commit real secrets.

# ----------
# Runtime
# ----------
APP_NAME=Upbrando EMS Backend
APP_VERSION=1.0.0
ENV=dev
PORT=8000
API_PREFIX=/api/v1
DEFAULT_TENANT_ID=default
MIGRATE_ON_START=false

# ----------
# Database
# ----------
# DEV (docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ems
# PROD example:
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<rds-endpoint>:5432/<db_name>

# ----------
# JWT / Crypto
# ----------
# Generate strong values:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace_with_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace_with_fernet_key

# ----------
# Google OAuth + Company Policy
# ----------
GOOGLE_CLIENT_ID=replace_with_google_client_id.apps.googleusercontent.com
COMPANY_EMAIL_DOMAIN=upbrando.com
# Optional exact email allowlist (comma-separated)
COMPANY_EMAIL_ALLOWLIST=

# ----------
# CORS
# ----------
# DEV: include Vite local origin.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://www.upbrando.com
# PROD recommended:
# CORS_ALLOWED_ORIGINS=https://www.upbrando.com

# ----------
# Rate Limits
# ----------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_CHAT_REQUESTS=60

# ----------
# Auth Cookies (HttpOnly session cookies)
# ----------
AUTH_ACCESS_COOKIE_NAME=ems_access_token
AUTH_REFRESH_COOKIE_NAME=ems_refresh_token

# DEV recommended:
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# PROD required:
# AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_DOMAIN=.upbrando.com

# ----------
# Superadmin Bootstrap
# ----------
SUPERADMIN_EMAIL=superadmin@upbrando.com
# Optional for bootstrap flow only. Keep empty if Google-only onboarding is preferred.
SUPERADMIN_PASSWORD=

# ----------
# Dev-only Auth Helper
# ----------
# Must remain false in prod. App hard-blocks bypass unless ENV=dev.
DEV_AUTH_BYPASS=false

# ----------
# Optional Office IP allowlist
# ----------
# OFFICE_IP_ALLOWLIST=1.2.3.4,5.6.7.8
OFFICE_IP_ALLOWLIST=

# ----------
# S3 Attachments
# ----------
# PROD (AWS S3): endpoint empty, use IAM role or access keys
S3_BUCKET=upbrando-ems-attachments
S3_REGION=ap-south-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
PRESIGNED_URL_EXPIRES_SECONDS=900
MAX_UPLOAD_BYTES=26214400
ATTACHMENTS_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,application/pdf,text/plain
