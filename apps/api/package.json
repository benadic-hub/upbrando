{
  "name": "@upbrando/api",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --skip-seed --skip-generate",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "prisma migrate reset --force --skip-seed --skip-generate && pnpm run db:seed",
    "db:studio": "prisma studio",
    "prisma:generate": "pnpm run db:generate",
    "prisma:migrate": "pnpm run db:migrate",
    "prisma:seed": "pnpm run db:seed",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "prisma": "^6.16.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
