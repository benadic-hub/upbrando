ENV=dev
PORT=5174
DATABASE_URL=file:./dev.db

# Required. Use a long random value locally and in all environments.
COOKIE_SECRET=replace_with_min_16_chars_cookie_secret
COOKIE_NAME=sid

# Required. Use current web dev origin on your machine.
CORS_ORIGIN=http://localhost:5175
# Optional additional origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional: override JWT secrets; defaults to COOKIE_SECRET when unset.
JWT_ACCESS_SECRET=replace_with_min_32_chars_access_secret
JWT_REFRESH_SECRET=replace_with_min_32_chars_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

AUTH_ACCESS_COOKIE_NAME=sid
AUTH_REFRESH_COOKIE_NAME=sid_refresh
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
